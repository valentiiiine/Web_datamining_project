<http://example.org/tennis/player/Marcos_Baghdatis> a ns2:Player ;
    rdfs:label "Marcos Baghdatis" ;
    ns2:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    ns3:evidenceText "At Wimbledon, Djokovic won a five-hour quarterfinal over Marcos Baghdatis before retiring in the semifinals against Nadal due to elbow issues.[65][66]" ;
