        <http://example.org/tennis/player/Rafael_Nadal> .

<http://example.org/tennis/player/Rublev> a ns2:Player ;
    rdfs:label "Rublev" ;
    ns2:playedAgainst <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Stefanos_Tsitsipas> ;
    ns3:evidenceText "At the ATP Finals, Nadal defeated Rublev and defending champion Tsitsipas progressing to the semi-finals and securing ending the year as No. 2.[338]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Sergiy_Stakhovsky> a ns2:Player ;
    rdfs:label "Sergiy Stakhovsky" ;
    ns2:playedAgainst <http://example.org/tennis/player/Marc_Lopez>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "Nadal helped Spain secure a Davis Cup World Group place for 2014, beating Sergiy Stakhovsky and winning a doubles with Marc Lopez." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Tommy_Haas> a ns2:Player ;
    rdfs:label "Tommy Haas" ;
    ns2:playedAgainst <http://example.org/tennis/player/Haas>,
        <http://example.org/tennis/player/Novak_Djokovic> ;
    ns3:evidenceText "Djokovic reached the final of the Gerry Weber Open on grass but lost to Tommy Haas, and then suffered another defeat to Haas in the quarterfinals of Wimbledon.[101][102]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

