<http://example.org/tennis/country/Spain> a ns2:Country ;
    rdfs:label "Spain" ;
    owl:sameAs <http://www.wikidata.org/entity/Q29> .

<http://example.org/tennis/player/Albert_Montanes> a ns2:Player ;
    rdfs:label "Albert Montañés" ;
    ns2:playedAgainst <http://example.org/tennis/player/Albert_Portas>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "In October, Nadal defeated No. 76 Albert Montañés in the quarterfinals of a Challenger at Barcelona,[16] before losing to Albert Portas in the semi-finals.[45]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Albert_Portas> a ns2:Player ;
    rdfs:label "Albert Portas" ;
    ns2:playedAgainst <http://example.org/tennis/player/Albert_Montanes>,
        <http://example.org/tennis/player/Rafael_Nadal> .

<http://example.org/tennis/player/Andre_Agassi> a ns2:Player ;
    rdfs:label "Andre Agassi" ;
    ns2:playedAgainst <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns2:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    ns3:evidenceText "Following his Wimbledon loss, Nadal won 16 consecutive matches and three consecutive tournaments, the Swedish Open, Stuttgart Open, and the Canada Masters, defeating Agassi in the final of the latter to win the first hardcourt title of his career and to bring his ranking to No. 2 on 25 July 2005, where he remained for the next three years behind Roger Federer.[36]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q7407> .

<http://example.org/tennis/player/Andre_Agassi_s> a ns2:Player ;
    rdfs:label "Andre Agassi's" ;
    ns2:playedAgainst <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Roger_Federer> .

<http://example.org/tennis/player/Anthony_Wilding> a ns2:Player ;
    rdfs:label "Anthony Wilding" ;
    ns2:fromCountry <http://example.org/tennis/country/New_Zealand> ;
    ns2:playedAgainst <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Roger_Federer> ;
    ns3:evidenceText "Winners of this tournament included world No. 1s such as Anthony Wilding from New Zealand (1913, 1914) and Bill Tilden from the US (1921)." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/French_Open"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q505788> .

<http://example.org/tennis/player/Boris_Becker> a ns2:Player ;
    rdfs:label "Boris Becker" ;
    ns2:playedAgainst <http://example.org/tennis/player/Mario_Ancic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns2:won <http://example.org/tennis/tournament/French_Open> ;
    ns3:evidenceText "Other notable players who have won multiple Grand Slam events but have never won the French Open, includes John McEnroe, Jimmy Connors, John Newcombe, Venus Williams, Stefan Edberg, Virginia Wade, Boris Becker, Andy Murray, Louise Brough, and Martina" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/French_Open"^^xsd:anyURI .

<http://example.org/tennis/player/Camilo_Ugo_Carabelli> a ns2:Player ;
    rdfs:label "Camilo Ugo Carabelli" ;
    ns2:playedAgainst <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "At the 2025 Miami Open, Djokovic beat lucky loser Camilo Ugo Carabelli in the third round to claim his record 411th career main draw win at the Masters 1000 level, surpassing Nadal's previous record of 410.[309]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

<http://example.org/tennis/player/Carlos_Moya> a ns2:Player ;
    rdfs:label "Carlos Moyá" ;
    ns2:playedAgainst <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Richard_Gasquet> .

<http://example.org/tennis/player/Cash> a ns2:Player ;
    rdfs:label "Cash" ;
    ns2:playedAgainst <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "Pat Cash emphasized that Djokovic is one of two players who beat Rafael Nadal at the French Open, which he considers to be \"the biggest challenge in tennis\".[591]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

<http://example.org/tennis/player/Del_Potro> a ns2:Player ;
    rdfs:label "Del Potro" ;
    ns2:playedAgainst <http://example.org/tennis/player/Andy_Murray>,
        <http://example.org/tennis/player/Novak_Djokovic> ;
    ns3:evidenceText "At Wimbledon, Djokovic defeated Del Potro in a historic semifinal lasting 4 hours and 44 minutes,[149] but lost the final to Murray in straight sets." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

<http://example.org/tennis/player/Denis_Shapovalov> a ns2:Player ;
    rdfs:label "Denis Shapovalov" ;
    ns2:playedAgainst <http://example.org/tennis/player/John_Isner>,
        <http://example.org/tennis/player/Novak_Djokovic> ;
    ns3:evidenceText "He won a record-extending tenth Italian Open title,[345] saving two match points against Denis Shapovalov before beating Novak Djokovic in the final." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q20979382> .

<http://example.org/tennis/player/Fernando_Gonzalez> a ns2:Player ;
    rdfs:label "Fernando González" ;
    ns2:playedAgainst <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "At the French Open, Djokovic, then world No. 63, defeated ninth seed Fernando González en route to his first Grand Slam quarterfinal,[52] where, due to issues with his back, he retired against Rafael Nadal after two sets in their first career meeting, launching their historic rivalry.[53]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

<http://example.org/tennis/player/Grigor_Dimitrov> a ns2:Player ;
    rdfs:label "Grigor Dimitrov" ;
    ns2:playedAgainst <http://example.org/tennis/player/Jannik_Sinner>,
        <http://example.org/tennis/player/Novak_Djokovic> .

<http://example.org/tennis/player/Guillermo_Canas> a ns2:Player ;
    rdfs:label "Guillermo Cañas" ;
    ns2:playedAgainst <http://example.org/tennis/player/Andy_Murray>,
        <http://example.org/tennis/player/Rafael_Nadal> .

<http://example.org/tennis/player/Guillermo_Vilas_s> a ns2:Player ;
    rdfs:label "Guillermo Vilas's" ;
    ns2:playedAgainst <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Robin_Soderling> ;
    ns3:evidenceText "Nadal then broke Argentinian Guillermo Vilas's 29-year male record of 53 consecutive clay-court match victories by beating Robin Söderling in the first round of the French Open.[85][86]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Haas> a ns2:Player ;
    rdfs:label "Haas" ;
    ns2:playedAgainst <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Tommy_Haas> ;
    ns3:evidenceText "- \"Haas beats Djokovic to win title\"." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

<http://example.org/tennis/player/Holger_Rune> a ns2:Player ;
    rdfs:label "Holger Rune" ;
    ns2:playedAgainst <http://example.org/tennis/player/Carlos_Alcaraz>,
        <http://example.org/tennis/player/Novak_Djokovic> .

<http://example.org/tennis/player/Janko_Tipsarevic> a ns2:Player ;
    rdfs:label "Janko Tipsarević" ;
    ns2:playedAgainst <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "In March, Nadal beat Janko Tipsarević and Novak Djokovic to help Spain beat Serbia in Davis Cup round one.[135][136]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Joachim_Johansson> a ns2:Player ;
    rdfs:label "Joachim Johansson" ;
    ns2:playedAgainst <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Tomas_Berdych> ;
    ns3:evidenceText "Joachim Johansson, ranked No. 690, upset Nadal in the second round of the Stockholm Open[92] and he lost to Tomáš Berdych in the quarterfinals of the Madrid Masters." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Karen_Khachanov> a ns2:Player ;
    rdfs:label "Karen Khachanov" ;
    ns2:playedAgainst <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> .

<http://example.org/tennis/player/La_Decima> a ns2:Player ;
    rdfs:label "La Décima" ;
    ns2:playedAgainst <http://example.org/tennis/player/Milos_Raonic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "La Décima, third US Open title, year-end No. 1 At the Brisbane International Nadal lost to Milos Raonic in the quarterfinals.[289]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Luca_Nardi> a ns2:Player ;
