<http://example.org/tennis/player/Botic_van_de_Zandschulp> a ns2:Player ;
    rdfs:label "Botic van de Zandschulp" ;
    ns2:participatedIn <http://example.org/tennis/tournament/US_Open> ;
    ns2:playedAgainst <http://example.org/tennis/player/Carlos_Alcaraz>,
        <http://example.org/tennis/player/Luca_Nardi>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "At the Davis Cup Finals in Málaga, Botic van de Zandschulp beat Nadal as Spain lost to the Netherlands in the quarterfinals.[377][378]",
        "Djokovic's next tournament was the Indian Wells Open, where he suffered a second-round defeat to lucky loser Botic van de Zandschulp – the 2nd year in a row where he lost to a lucky loser at the same tournament, following Luca Nardi.",
        "He next played the 2024 US Open, where he suffered a shocking second-round defeat in straight sets to Botic van de Zandschulp." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q28038578> .

<http://example.org/tennis/player/Cameron_Norrie> a ns2:Player ;
    rdfs:label "Cameron Norrie" ;
    ns2:playedAgainst <http://example.org/tennis/player/Carlos_Alcaraz>,
        <http://example.org/tennis/player/Nick_Kyrgios>,
        <http://example.org/tennis/player/Rafael_Nadal_78>,
        <http://example.org/tennis/player/Roger_Federer> ;
    ns3:evidenceText "\"Cameron Norrie beats world No 2 Carlos Alcaraz to claim Rio Open\".",
        "At Indian Wells, Alcaraz defeated defending champion Cameron Norrie to reach his first Masters quarterfinal and semifinal, which he lost to Rafael Nadal.[78]",
        "He reached a record 32nd Grand Slam final after defeating Cameron Norrie in the semifinals[275] and beat Nick Kyrgios in four sets to claim his seventh Wimbledon and 21st major title, surpassing Roger Federer and moving one behind Nadal.[276][277]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q23668736> .

<http://example.org/tennis/player/Daniil_Medvedev> a ns2:Player ;
    rdfs:label "Daniil Medvedev" ;
    ns2:playedAgainst <http://example.org/tennis/player/Dominic_Thiem>,
        <http://example.org/tennis/player/Jannik_Sinner>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns2:won <http://example.org/tennis/tournament/Australian_Open> ;
    ns3:evidenceText "- \"Daniil Medvedev beats Rafael Nadal to set up ATP Finals clash with Dominic Thiem\".",
        "Daniil Medvedev defeated Novak Djokovic in the final, 6–4, 6–4, 6–4 to win the men's singles tennis title at the 2021 US Open.[1]",
        "He then won his ninth Australian Open title and 18th major overall, defeating Daniil Medvedev in the final.[240]",
        "He won his second Australian Open title, 21st major title and 90th ATP title beating Daniil Medvedev in a five-set final, coming back from two sets down.[349" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/2021_US_Open_%E2%80%93_Men%27s_singles"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q190239> .

<http://example.org/tennis/player/David_Ferrer> a ns2:Player ;
    rdfs:label "David Ferrer" ;
    ns2:playedAgainst <http://example.org/tennis/player/Andy_Murray>,
        <http://example.org/tennis/player/John_Isner>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns2:won <http://example.org/tennis/tournament/French_Open> ;
    ns3:evidenceText "At the French Open, Nadal won his semi-final match against Ferrer to set up another final against Novak Djokovic.",
        "In Miami, he defeated David Ferrer and John Isner en route to winning his fifth title, defeating Andy Murray in three sets.",
        "Nadal won the French Open beating David Ferrer in the final, breaking the record for the most match wins in the tournament with his 59th victory.[237]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q191476> .

<http://example.org/tennis/player/Gael_Monfils> a ns2:Player ;
    rdfs:label "Gael Monfils",
        "Gaël Monfils" ;
    ns2:playedAgainst <http://example.org/tennis/player/Mario_Ancic_46>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Vajda> ;
    ns2:won <http://example.org/tennis/tournament/French_Open> ;
    ns3:evidenceText "2014: Ninth French Open title and sustained injuries At the Qatar Open, Nadal won the title beating Gaël Monfils in the final.[250]",
        "Djokovic's Grand Slam debut came at the 2005 Australian Open, followed by his first Slam win at the French Open.[10]: 89–91 That year, he also reached the third round at both Wimbledon[10]: 91 and the US Open, where he beat Gaël Monfils and Mario Ančić.[46]",
        "He began the grass season at the Eastbourne International, winning the title by beating Gaël Monfils—his only tournament win without Vajda until their 2022 split." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q186429> .

<http://example.org/tennis/player/Jo_Wilfried_Tsonga> a ns2:Player ;
    rdfs:label "Jo-Wilfried Tsonga" ;
    ns2:playedAgainst <http://example.org/tennis/player/Andy_Murray>,
        <http://example.org/tennis/player/Juan_Martin_del_Potro>,
        <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Roger_Federer> ;
    ns3:evidenceText "He beat Jo-Wilfried Tsonga to reach the semifinals but lost to Murray and then to Juan Martín del Potro in the bronze medal match, finishing fourth." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q192661> .

