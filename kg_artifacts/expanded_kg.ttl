<http://example.org/tennis/player/Casper_Ruud> a ns2:Player ;
    rdfs:label "Casper Ruud" ;
    ns2:playedAgainst <http://example.org/tennis/player/Alexander_Zverev>,
        <http://example.org/tennis/player/Andrey_Rublev>,
        <http://example.org/tennis/player/Carlos_Alcaraz>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "He was unwell during the ATP Finals but did not withdraw, beating Andrey Rublev but losing to Casper Ruud and Alexander Zverev in straight sets to exit the tournament at the round robin stage.[183]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q18810082> .

<http://example.org/tennis/player/Dominic_Thiem> a ns2:Player ;
    rdfs:label "Dominic Thiem" ;
    ns2:playedAgainst <http://example.org/tennis/player/Daniil_Medvedev>,
        <http://example.org/tennis/player/Nick_Kyrgios>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Roger_Federer> ;
    ns3:evidenceText "At Madrid, he beat Dominic Thiem to tie Djokovic's all-time Masters record of 30 titles.[293]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q88762> .

<http://example.org/tennis/player/Jannik_Sinner> a ns2:Player ;
    rdfs:label "Jannik Sinner" ;
    ns2:participatedIn <http://example.org/tennis/tournament/Australian_Open> ;
    ns2:playedAgainst <http://example.org/tennis/player/Carlos_Alcaraz>,
        <http://example.org/tennis/player/Daniil_Medvedev>,
        <http://example.org/tennis/player/Diego_Schwartzman>,
        <http://example.org/tennis/player/Grigor_Dimitrov>,
        <http://example.org/tennis/player/Novak_Djokovic> ;
    ns2:won <http://example.org/tennis/tournament/Australian_Open>,
        <http://example.org/tennis/tournament/French_Open>,
        <http://example.org/tennis/tournament/US_Open>,
        <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    ns3:evidenceText "- \"ATP Finals: Jannik Sinner beats Carlos Alcaraz to defend title in Turin\".",
        "- \"Sinner Storms Back To Beat Alcaraz In Miami SF, Ending Spaniard's No. 1 Reign\".",
        "Alcaraz won their first major final at the French Open, despite Sinner holding three championship points in the fourth set.",
        "At the French Open, he beat Jannik Sinner and Diego Schwartzman before losing in the semis to eventual champion Djokovic in four sets, in only his third-ever loss at the French Open and his first loss in the semi-finals.",
        "He defeated Jannik Sinner in the semifinal and Daniil Medvedev in the final to lift the trophy.[123]",
        "He lost to Jannik Sinner in the semifinals of Beijing, and then to Grigor Dimitrov in the round of 16 at Shanghai.[146][147]",
        "The pair have played some notable matches, including the final of the 2023 ATP Finals, which Djokovic won,[379] the 2024 Australian Open semifinal, which Sinner won in four sets,[380] and the 2024 Shanghai Masters final, which Sinner won in straight sets.[381]",
        "They also contested two Masters finals in 2025, at the Italian Open and the Cincinnati Open, both won by Alcaraz;[239][240] and the final of the 2025 ATP Finals, where Sinner defeated Alcaraz in straight sets.[241]",
        "They met again at Wimbledon, where Sinner won in four sets, dethroning defending champion Alcaraz; and at the US Open, where Alcaraz won in four sets, dethroning defending champion Sinner.[238]",
        "They met back to back in the semifinals at the 2025 French Open and 2025 Wimbledon, where Sinner won both times" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q64769553> .

<http://example.org/tennis/player/John_Isner> a ns2:Player ;
    rdfs:label "John Isner" ;
    ns2:playedAgainst <http://example.org/tennis/player/Andy_Murray>,
        <http://example.org/tennis/player/David_Ferrer>,
        <http://example.org/tennis/player/Denis_Shapovalov>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "At Rome, he beat John Isner in straight sets, but lost to Denis Shapovalov in three sets despite leading by a set and a break.",
        "Djokovic then lost to John Isner in the semifinals of Indian Wells but retained his Miami title by defeating Murray.",
        "In Miami, he defeated David Ferrer and John Isner en route to winning his fifth title, defeating Andy Murray in three sets." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q53566> .

<http://example.org/tennis/player/Kei_Nishikori> a ns2:Player ;
    rdfs:label "Kei Nishikori" ;
    ns2:playedAgainst <http://example.org/tennis/player/Kyle_Edmund>,
        <http://example.org/tennis/player/Martin_Klizan>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Roger_Federer> ;
    ns3:evidenceText "- \"US Open: Kei Nishikori beats Novak Djokovic in the semi-finals\".",
        "At the French Open, Nadal beat Kei Nishikori and Roger Federer (their first meeting at the tournament since 2011) en route to the final, dropping only one set en route.",
        "Following an early loss at Barcelona to Martin Kližan, he showed improvement at the Madrid Open by beating Kei Nishikori—his first top 20 win in 10 months—but lost to Kyle Edmund in the second round.[201][202]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q311222> .

<http://example.org/tennis/player/Nick_Kyrgios> a ns2:Player ;
    rdfs:label "Nick Kyrgios" ;
    ns2:playedAgainst <http://example.org/tennis/player/Cameron_Norrie>,
        <http://example.org/tennis/player/Carlos_Alcaraz>,
        <http://example.org/tennis/player/Dominic_Thiem>,
        <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Roger_Federer> ;
    ns3:evidenceText "At Indian Wells he beat Nick Kyrgios and Carlos Alcaraz to reach his fourth final of the year and extend his winning streak to 20 matches.[351]",
        "He reached a record 32nd Grand Slam final after defeating Cameron Norrie in the semifinals[275] and beat Nick Kyrgios in four sets to claim his seventh Wimbledon and 21st major title, surpassing Roger Federer and moving one behind Nadal.[276][277]",
        "In the fourth round, he defeated Nick Kyrgios in four sets and lost in the quarterfinals to eventual runner-up Dominic Thiem in four sets.[330]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q3720084> .

<http://example.org/tennis/player/Stefanos_Tsitsipas> a ns2:Player ;
    rdfs:label "Stefanos Tsitsipas" ;
    ns2:playedAgainst <http://example.org/tennis/player/Carlos_Alcaraz>,
        <http://example.org/tennis/player/Medvedev>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Rublev> ;
    ns3:evidenceText "- \"Djokovic Beats Tsitsipas For Madrid Title, Tying Nadal's Masters 1000 Record\".",
        "At the ATP Finals, Nadal beat Tsitsipas and Medvedev in the round-robin stage, but failed to progress to the semi-finals.[324]",
        "By defeating world No. 3 Stefanos Tsitsipas in the third round, Carlos Alcaraz became the youngest man to beat a top 3 ranked-player in singles at the US Open since the inception of the ATP rankings in 1973." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/2021_US_Open_%E2%80%93_Men%27s_singles"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q310510> .

