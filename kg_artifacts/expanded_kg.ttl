    ns2:playedAgainst <http://example.org/tennis/player/Cameron_Norrie>,
        <http://example.org/tennis/player/Carlos_Alcaraz> .

<http://example.org/tennis/player/Ricardo_Villacorta> a ns2:Player ;
    rdfs:label "Ricardo Villacorta" ;
    ns2:playedAgainst <http://example.org/tennis/player/Marcel_Granollers>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "Career Nadal won the Spanish junior championships in 1997 and 1998, beating Ricardo Villacorta and Marcel Granollers respectively.[16][17]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Richard_Gasquet> a ns2:Player ;
    rdfs:label "Richard Gasquet" ;
    ns2:playedAgainst <http://example.org/tennis/player/Carlos_Moya>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "In September, Nadal entered the final Challenger event of his career, on hard courts in Saint-Jean-de-Luz, retiring with an injury against Richard Gasquet, who never defeated Nadal again.[48][56]",
        "On clay, he defeated Richard Gasquet in the final of the Estoril Open,[60] and reached the quarterfinals in Rome and Hamburg, losing to Nadal and Carlos Moyá, respectively.[61][62]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q209436> .

