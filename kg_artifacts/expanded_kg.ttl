<http://example.org/tennis/player/Andrey_Rublev> a ns2:Player ;
    rdfs:label "Andrey Rublev" ;
    ns2:playedAgainst <http://example.org/tennis/player/Alexander_Zverev>,
        <http://example.org/tennis/player/Casper_Ruud>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "He was unwell during the ATP Finals but did not withdraw, beating Andrey Rublev but losing to Casper Ruud and Alexander Zverev in straight sets to exit the tournament at the round robin stage.[183]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q17373391> .

<http://example.org/tennis/player/Diego_Schwartzman> a ns2:Player ;
    rdfs:label "Diego Schwartzman" ;
    ns2:playedAgainst <http://example.org/tennis/player/Jannik_Sinner>,
        <http://example.org/tennis/player/John_McEnroe_s>,
        <http://example.org/tennis/player/Novak_Djokovic> ;
    ns3:evidenceText "At Madrid, he beat Diego Schwartzman in straight sets, to extend his record to 50 consecutive sets won on clay and broke John McEnroe's record of 49 straight sets won on a single surface.[305]",
        "At the French Open, he beat Jannik Sinner and Diego Schwartzman before losing in the semis to eventual champion Djokovic in four sets, in only his third-ever loss at the French Open and his first loss in the semi-finals." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Fognini> a ns2:Player ;
    rdfs:label "Fognini" ;
    ns2:playedAgainst <http://example.org/tennis/player/Andy_Murray>,
        <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "At Monte Carlo he lost to Novak Djokovic in straight sets in the semi finals,[266] at Barcelona he lost to Fognini in the quarterfinals[267] and at Madrid he lost the final to Andy Murray in straight sets, resulting in his dropping out of the top five for the first time since 2005.[268][269]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Frances_Tiafoe> a ns2:Player ;
    rdfs:label "Frances Tiafoe" ;
    ns2:playedAgainst <http://example.org/tennis/player/Alexander_Zverev>,
        <http://example.org/tennis/player/Carlos_Alcaraz>,
        <http://example.org/tennis/player/Nikola_Miloje> ;
    ns3:evidenceText "He received wildcards at the Mexican Open, where he lost to eventual champion Alexander Zverev in the first round;[49] at the Barcelona Open, where he lost to Frances Tiafoe in the first round;[50] and at the Andalucía Open, where he defeated Nikola Miloje" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q17305299> .

<http://example.org/tennis/player/Kevin_Anderson> a ns2:Player ;
    rdfs:label "Kevin Anderson" ;
    ns2:playedAgainst <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Roger_Federer_172> ;
    ns3:evidenceText "Five weeks later, he beat Kevin Anderson in the fourth round in five sets, and then went on to claim his third Wimbledon title with a win over Roger Federer.[172]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q299956> .

