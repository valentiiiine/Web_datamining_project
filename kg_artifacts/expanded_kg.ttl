<http://example.org/tennis/tournament/US_Open> a ns2:Tournament ;
    rdfs:label "US Open" ;
    ns2:hasSurface <http://example.org/tennis/surface/Clay>,
        <http://example.org/tennis/surface/Grass>,
        <http://example.org/tennis/surface/Hard_Court> ;
    ns3:evidenceText "He became the first man to win majors on clay, grass, and hard courts in the same year, and the first to win the French Open, Wimbledon, and the US Open in the same year since Rod Laver in 1969.[178]",
        "He won his 4th hard court title of the year, defeating Djokovic in the US Open final to achieve the Summer Slam and clinch the US Open Series.[245",
        "Jimmy Connors is the only individual to have won US Open singles titles on all three surfaces (grass, clay, and hardcourt), while Chris Evert is the only woman to have won US Open singles titles on two surfaces (clay and hardcourt).[6]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/US_Open_(tennis)"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q123577> .

