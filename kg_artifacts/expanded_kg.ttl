<http://example.org/tennis/player/Martina_Navratilova> a ns2:Player ;
    rdfs:label "Martina Navratilova" ;
    ns2:won <http://example.org/tennis/tournament/French_Open> ;
    ns3:evidenceText "When Martina Navratilova won the 1984 French Open and became the reigning champion of all four women's singles discipline, she was the first player to receive the bonus prize in recognition of her achievement." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Grand_Slam_(tennis)"^^xsd:anyURI .

