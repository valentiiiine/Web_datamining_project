<http://example.org/tennis/player/Margaret_Court_s> a ns2:Player ;
    rdfs:label "Margaret Court's" ;
    ns2:won <http://example.org/tennis/tournament/Australian_Open> ;
    ns3:evidenceText "This tied Margaret Court's record for singles titles at a Grand Slam event (Court won 11 Australian Opens)." ;
