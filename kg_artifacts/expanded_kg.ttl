        <http://example.org/tennis/player/Sergiy_Stakhovsky> .

<http://example.org/tennis/player/Marcel_Granollers> a ns2:Player ;
    rdfs:label "Marcel Granollers" ;
    ns2:playedAgainst <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Ricardo_Villacorta> .

<http://example.org/tennis/player/Marin_Cilic> a ns2:Player ;
    rdfs:label "Marin Čilić" ;
    ns2:playedAgainst <http://example.org/tennis/player/Medvedev>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "At the US Open, Nadal lost one set (against Marin Čilić) en route to the final, where he beat Medvedev in five sets to win his fourth US Open title and 19th major title overall, and completed his second-best Grand Slam year.[322]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Mario_Ancic> a ns2:Player ;
    rdfs:label "Mario Ančić" ;
    ns2:playedAgainst <http://example.org/tennis/player/Boris_Becker>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    ns3:evidenceText "major main draw debut in Wimbledon, Nadal defeated Mario Ančić, and reached the third round to become the youngest man to do so since Boris Becker in 1984.[31][52]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Mario_Ancic_46> a ns2:Player ;
    rdfs:label "Mario Ančić.[46" ;
    ns2:playedAgainst <http://example.org/tennis/player/Gael_Monfils>,
        <http://example.org/tennis/player/Novak_Djokovic> .

<http://example.org/tennis/player/Martin_Klizan> a ns2:Player ;
    rdfs:label "Martin Kližan" ;
    ns2:playedAgainst <http://example.org/tennis/player/Kei_Nishikori>,
        <http://example.org/tennis/player/Kyle_Edmund> ;
    ns3:evidenceText "Following an early loss at Barcelona to Martin Kližan, he showed improvement at the Madrid Open by beating Kei Nishikori—his first top 20 win in 10 months—but lost to Kyle Edmund in the second round.[201][202]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

<http://example.org/tennis/player/Matteo_Berrettini> a ns2:Player ;
    rdfs:label "Matteo Berrettini" ;
    ns2:playedAgainst <http://example.org/tennis/player/Rafael_Nadal>,
        <http://example.org/tennis/player/Roger_Federer> ;
    ns3:evidenceText "At Wimbledon, he earned his 100th grass-court win en route to the final,[250] where he defeated Matteo Berrettini to win his sixth title and 20th major, tying Federer and Nadal." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

<http://example.org/tennis/player/Nikola_Miloje> a ns2:Player ;
    rdfs:label "Nikola Miloje" ;
    ns2:playedAgainst <http://example.org/tennis/player/Alexander_Zverev>,
        <http://example.org/tennis/player/Frances_Tiafoe> .

<http://example.org/tennis/player/Philipp_Kohlschreiber> a ns2:Player ;
    rdfs:label "Philipp Kohlschreiber" ;
    ns2:participatedIn <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    ns2:playedAgainst <http://example.org/tennis/player/Alexander_Zverev_301>,
        <http://example.org/tennis/player/Novak_Djokovic> ;
    ns3:evidenceText "As a warm-up ahead of Wimbledon, Nadal played in Halle, losing to Philipp Kohlschreiber in the quarterfinals.[223]",
        "He beat Philipp Kohlschreiber and Alexander Zverev.[301]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI ;
    owl:sameAs <http://www.wikidata.org/entity/Q77149> .

<http://example.org/tennis/player/Rafael_Nadal_78> a ns2:Player ;
