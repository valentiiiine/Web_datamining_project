@prefix ns1: <http://www.wikidata.org/prop/direct/> .
@prefix ns2: <http://example.org/tennis/ontology/> .
@prefix ns3: <http://example.org/tennis/provenance/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns2:editionYear rdfs:comment "Mapped to 'point in time' because the local editionYear is a simplified temporal encoding of a tournament edition." ;
    rdfs:seeAlso <http://www.wikidata.org/entity/P585> ;
    rdfs:subPropertyOf ns1:P585 .

ns2:fromCountry rdfs:comment "Mapped conservatively to 'country of citizenship'. It is not always strictly identical to nationality in sports text, so subPropertyOf is safer than equivalence." ;
    rdfs:seeAlso <http://www.wikidata.org/entity/P27> ;
    rdfs:subPropertyOf ns1:P27 .

ns2:participatedIn rdfs:comment "Mapped to Wikidata 'participant in' because the local predicate captures participation in a tournament event." ;
    rdfs:seeAlso <http://www.wikidata.org/entity/P1344> ;
    rdfs:subPropertyOf ns1:P1344 .

ns2:won rdfs:comment "Mapped conservatively to Wikidata 'winner' because the local predicate links a player to a tournament and is more specific than a generic award relation." ;
    rdfs:seeAlso <http://www.wikidata.org/entity/P1346> ;
    rdfs:subPropertyOf ns1:P1346 .

<http://example.org/tennis/player/Alcaraz_Jannik_Sinner> a ns2:Player ;
    rdfs:label "Alcaraz-Jannik Sinner" ;
    ns2:participatedIn <http://example.org/tennis/tournament/French_Open> ;
    ns3:evidenceText "s Alcaraz-Jannik Sinner Roland Garros match the best ever played?\"." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI .

<http://example.org/tennis/player/Annabel_Croft> a ns2:Player ;
    rdfs:label "Annabel Croft" ;
    ns2:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    ns3:evidenceText "No British man won the singles event at Wimbledon between Fred Perry in 1936 and Andy Murray in 2013, while no British woman has won since Virginia Wade in 1977, although Annabel Croft and Laura Robson won the Girls' Championship in 1984 and 2008 respectively." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Wimbledon_Championships"^^xsd:anyURI .

<http://example.org/tennis/player/Arthur_Ashe> a ns2:Player ;
    rdfs:label "Arthur Ashe" ;
    ns2:won <http://example.org/tennis/tournament/US_Open> ;
    ns3:evidenceText "The stadium is named after Arthur Ashe, who won the men's singles title at the inaugural US Open in 1968, and was inducted into the International Tennis Hall of Fame in 1985." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/US_Open_(tennis)"^^xsd:anyURI .

<http://example.org/tennis/player/Benito_Barbadillo> a ns2:Player ;
    rdfs:label "Benito Barbadillo" ;
    ns2:fromCountry <http://example.org/tennis/country/Jerez> ;
    ns3:evidenceText "- \"Benito Barbadillo: 'From Jerez circuit to becoming Nadal's agent, here is my life'." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Bertrand_Milbourne_Clark> a ns2:Player ;
    rdfs:label "Bertrand Milbourne Clark" ;
    ns2:fromCountry <http://example.org/tennis/country/Jamaica> ;
    ns3:evidenceText "The first black player to compete at Wimbledon was Bertrand Milbourne Clark, an amateur from Jamaica, in 1924.[15]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Wimbledon_Championships"^^xsd:anyURI .

<http://example.org/tennis/player/Bjorn_Borg> a ns2:Player ;
    rdfs:label "Björn Borg" ;
    ns2:won <http://example.org/tennis/tournament/French_Open> ;
    ns3:evidenceText "On the other hand, notable players who have won multiple Grand Slam events and have won the French Open, includes Rafael Nadal, Björn Borg, Steffi Graf, Ivan Lendl, Monica Seles, Novak Djokovic, Mats Wilander, Serena Williams, Stan Wawrinka, Justine Henin and Chris Evert, showing proof of their great versatility." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/French_Open"^^xsd:anyURI .

<http://example.org/tennis/player/Brookes> a ns2:Player ;
    rdfs:label "Brookes" ;
    ns2:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    ns3:evidenceText "Brookes went to Europe only three times, where he reached the Wimbledon Challenge Round once and then won Wimbledon twice." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Australian_Open"^^xsd:anyURI .

<http://example.org/tennis/player/Chris_Evert> a ns2:Player ;
    rdfs:label "Chris Evert" ;
    ns2:won <http://example.org/tennis/tournament/French_Open>,
        <http://example.org/tennis/tournament/US_Open> ;
    ns3:evidenceText "Jimmy Connors is the only individual to have won US Open singles titles on all three surfaces (grass, clay, and hardcourt), while Chris Evert is the only woman to have won US Open singles titles on two surfaces (clay and hardcourt).[6]",
        "On the other hand, notable players who have won multiple Grand Slam events and have won the French Open, includes Rafael Nadal, Björn Borg, Steffi Graf, Ivan Lendl, Monica Seles, Novak Djokovic, Mats Wilander, Serena Williams, Stan Wawrinka, Justine Henin and Chris Evert, showing proof of their great versatility." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/French_Open"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/US_Open_(tennis)"^^xsd:anyURI .

<http://example.org/tennis/player/Fabio_Fognini> a ns2:Player ;
    rdfs:label "Fabio Fognini" ;
    ns2:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    ns3:evidenceText "In the first round of Wimbledon, Alcaraz was unexpectedly taken to five sets by Fabio Fognini, who had already announced his retirement and had not won a match all season.[209]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI .

<http://example.org/tennis/player/Federico_Delbonis> a ns2:Player ;
    rdfs:label "Federico Delbonis" ;
    ns2:won <http://example.org/tennis/tournament/Australian_Open> ;
    ns3:evidenceText "At the Australian Open Nadal won his first three matches in straight sets against Hugo Dellien, Federico Delbonis and Pablo Carreño Busta." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Fred_Perry> a ns2:Player ;
    rdfs:label "Fred Perry" ;
    ns2:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    ns3:evidenceText "No British man won the singles event at Wimbledon between Fred Perry in 1936 and Andy Murray in 2013, while no British woman has won since Virginia Wade in 1977, although Annabel Croft and Laura Robson won the Girls' Championship in 1984 and 2008 respectively." ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Wimbledon_Championships"^^xsd:anyURI .

<http://example.org/tennis/player/Gencic> a ns2:Player ;
    rdfs:label "Genčić" ;
    ns2:fromCountry <http://example.org/tennis/country/Munich> ;
    ns3:evidenceText "Genčić coached him in Belgrade from 1993 to 1999, while Pilić worked with him in Munich from 1999 to 2003.[13][16]" ;
    ns3:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

