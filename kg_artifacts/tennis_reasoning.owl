<swrl:Variable rdf:about="urn:swrl#p"/>

<swrl:Variable rdf:about="urn:swrl#n"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Player"/>
          <swrl:argument1 rdf:resource="urn:swrl#p"/>
