    onto:participatedIn <http://example.org/tennis/tournament/Australian_Open>,
        <http://example.org/tennis/tournament/French_Open> ;
    prov1:evidenceText "This marked only the second time in tennis history (after Serena and Venus Williams between the 2002 French Open and the 2003 Australian Open), two players played four consecutive major singles finals against each other." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

