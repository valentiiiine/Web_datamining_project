<http://example.org/tennis/player/Alexander_Zverev> a onto:Player ;
    rdfs:label "Alexander Zverev" ;
    onto:playedAgainst <http://example.org/tennis/player/Andrey_Rublev>,
        <http://example.org/tennis/player/Carlos_Alcaraz>,
