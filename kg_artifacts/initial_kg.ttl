    prov1:evidenceText "In October, Nadal defeated No. 76 Albert Montañés in the quarterfinals of a Challenger at Barcelona,[16] before losing to Albert Portas in the semi-finals.[45]" ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Albert_Portas> a onto:Player ;
