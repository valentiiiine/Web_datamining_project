<http://example.org/tennis/player/Alcaraz_Jannik_Sinner> a onto:Player ;
    rdfs:label "Alcaraz-Jannik Sinner" ;
    onto:participatedIn <http://example.org/tennis/tournament/French_Open> ;
    prov1:evidenceText "s Alcaraz-Jannik Sinner Roland Garros match the best ever played?\"." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI .

<http://example.org/tennis/player/Annabel_Croft> a onto:Player ;
    rdfs:label "Annabel Croft" ;
    onto:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    prov1:evidenceText "No British man won the singles event at Wimbledon between Fred Perry in 1936 and Andy Murray in 2013, while no British woman has won since Virginia Wade in 1977, although Annabel Croft and Laura Robson won the Girls' Championship in 1984 and 2008 respectively." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Wimbledon_Championships"^^xsd:anyURI .

<http://example.org/tennis/player/Arthur_Ashe> a onto:Player ;
    rdfs:label "Arthur Ashe" ;
    onto:won <http://example.org/tennis/tournament/US_Open> ;
    prov1:evidenceText "The stadium is named after Arthur Ashe, who won the men's singles title at the inaugural US Open in 1968, and was inducted into the International Tennis Hall of Fame in 1985." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/US_Open_(tennis)"^^xsd:anyURI .

<http://example.org/tennis/player/Benito_Barbadillo> a onto:Player ;
    rdfs:label "Benito Barbadillo" ;
    onto:fromCountry <http://example.org/tennis/country/Jerez> ;
    prov1:evidenceText "- \"Benito Barbadillo: 'From Jerez circuit to becoming Nadal's agent, here is my life'." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Bertrand_Milbourne_Clark> a onto:Player ;
    rdfs:label "Bertrand Milbourne Clark" ;
    onto:fromCountry <http://example.org/tennis/country/Jamaica> ;
    prov1:evidenceText "The first black player to compete at Wimbledon was Bertrand Milbourne Clark, an amateur from Jamaica, in 1924.[15]" ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Wimbledon_Championships"^^xsd:anyURI .

<http://example.org/tennis/player/Bjorn_Borg> a onto:Player ;
    rdfs:label "Björn Borg" ;
    onto:won <http://example.org/tennis/tournament/French_Open> ;
    prov1:evidenceText "On the other hand, notable players who have won multiple Grand Slam events and have won the French Open, includes Rafael Nadal, Björn Borg, Steffi Graf, Ivan Lendl, Monica Seles, Novak Djokovic, Mats Wilander, Serena Williams, Stan Wawrinka, Justine Henin and Chris Evert, showing proof of their great versatility." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/French_Open"^^xsd:anyURI .

<http://example.org/tennis/player/Brookes> a onto:Player ;
    rdfs:label "Brookes" ;
    onto:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    prov1:evidenceText "Brookes went to Europe only three times, where he reached the Wimbledon Challenge Round once and then won Wimbledon twice." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Australian_Open"^^xsd:anyURI .

<http://example.org/tennis/player/Chris_Evert> a onto:Player ;
    rdfs:label "Chris Evert" ;
    onto:won <http://example.org/tennis/tournament/French_Open>,
        <http://example.org/tennis/tournament/US_Open> ;
    prov1:evidenceText "Jimmy Connors is the only individual to have won US Open singles titles on all three surfaces (grass, clay, and hardcourt), while Chris Evert is the only woman to have won US Open singles titles on two surfaces (clay and hardcourt).[6]",
        "On the other hand, notable players who have won multiple Grand Slam events and have won the French Open, includes Rafael Nadal, Björn Borg, Steffi Graf, Ivan Lendl, Monica Seles, Novak Djokovic, Mats Wilander, Serena Williams, Stan Wawrinka, Justine Henin and Chris Evert, showing proof of their great versatility." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/French_Open"^^xsd:anyURI,
        "https://en.wikipedia.org/wiki/US_Open_(tennis)"^^xsd:anyURI .

<http://example.org/tennis/player/Fabio_Fognini> a onto:Player ;
    rdfs:label "Fabio Fognini" ;
    onto:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    prov1:evidenceText "In the first round of Wimbledon, Alcaraz was unexpectedly taken to five sets by Fabio Fognini, who had already announced his retirement and had not won a match all season.[209]" ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Carlos_Alcaraz"^^xsd:anyURI .

<http://example.org/tennis/player/Federico_Delbonis> a onto:Player ;
