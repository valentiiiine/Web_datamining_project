        <http://example.org/tennis/player/Rafael_Nadal> ;
    prov1:evidenceText "Pat Cash emphasized that Djokovic is one of two players who beat Rafael Nadal at the French Open, which he considers to be \"the biggest challenge in tennis\".[591]" ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

<http://example.org/tennis/player/Del_Potro> a onto:Player ;
    rdfs:label "Del Potro" ;
    onto:playedAgainst <http://example.org/tennis/player/Andy_Murray>,
        <http://example.org/tennis/player/Novak_Djokovic> ;
    prov1:evidenceText "At Wimbledon, Djokovic defeated Del Potro in a historic semifinal lasting 4 hours and 44 minutes,[149] but lost the final to Murray in straight sets." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

<http://example.org/tennis/player/Denis_Shapovalov> a onto:Player ;
