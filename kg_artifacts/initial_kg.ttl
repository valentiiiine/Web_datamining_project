    onto:won <http://example.org/tennis/tournament/Australian_Open> ;
    prov1:evidenceText "At the Australian Open Nadal won his first three matches in straight sets against Hugo Dellien, Federico Delbonis and Pablo Carreño Busta." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

