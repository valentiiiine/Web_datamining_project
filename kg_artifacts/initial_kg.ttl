<http://example.org/tennis/player/Roger_Federer_36> a onto:Player ;
    rdfs:label "Roger Federer.[36" ;
    onto:won <http://example.org/tennis/tournament/Wimbledon_Championships> ;
    prov1:evidenceText "Following his Wimbledon loss, Nadal won 16 consecutive matches and three consecutive tournaments, the Swedish Open, Stuttgart Open, and the Canada Masters, defeating Agassi in the final of the latter to win the first hardcourt title of his career and to bring his ranking to No. 2 on 25 July 2005, where he remained for the next three years behind Roger Federer.[36]" ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Serena> a onto:Player ;
