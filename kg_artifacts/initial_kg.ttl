    onto:won <http://example.org/tennis/tournament/French_Open> ;
    prov1:evidenceText "Other notable players who have won multiple Grand Slam events but have never won the French Open, includes John McEnroe, Jimmy Connors, John Newcombe, Venus Williams, Stefan Edberg, Virginia Wade, Boris Becker, Andy Murray, Louise Brough, and Martina" ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/French_Open"^^xsd:anyURI .

<http://example.org/tennis/player/Camilo_Ugo_Carabelli> a onto:Player ;
