<http://example.org/tennis/player/Nick_Kyrgios> a onto:Player ;
    rdfs:label "Nick Kyrgios" ;
    onto:playedAgainst <http://example.org/tennis/player/Cameron_Norrie>,
        <http://example.org/tennis/player/Carlos_Alcaraz>,
