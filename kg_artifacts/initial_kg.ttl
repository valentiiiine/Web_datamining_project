    onto:playedAgainst <http://example.org/tennis/player/John_Isner>,
        <http://example.org/tennis/player/Novak_Djokovic> ;
    prov1:evidenceText "He won a record-extending tenth Italian Open title,[345] saving two match points against Denis Shapovalov before beating Novak Djokovic in the final." ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Rafael_Nadal"^^xsd:anyURI .

<http://example.org/tennis/player/Fernando_Gonzalez> a onto:Player ;
    rdfs:label "Fernando González" ;
    onto:playedAgainst <http://example.org/tennis/player/Novak_Djokovic>,
        <http://example.org/tennis/player/Rafael_Nadal> ;
    prov1:evidenceText "At the French Open, Djokovic, then world No. 63, defeated ninth seed Fernando González en route to his first Grand Slam quarterfinal,[52] where, due to issues with his back, he retired against Rafael Nadal after two sets in their first career meeting, launching their historic rivalry.[53]" ;
    prov1:sourceURL "https://en.wikipedia.org/wiki/Novak_Djokovic"^^xsd:anyURI .

