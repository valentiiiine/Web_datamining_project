<http://example.org/tennis/player/Roger_Federer_196> a onto:Player ;
    rdfs:label "Roger Federer.[196" ;
    onto:won <http://example.org/tennis/tournament/French_Open> ;
    prov1:evidenceText "However, Nadal retained his No. 1 ranking during the clay-court season and won his sixth French Open title by defeating Roger Federer.[196]" ;
